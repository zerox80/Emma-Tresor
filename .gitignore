# EmmaTresor Git ignore configuration
# Keep comments on separate lines: Git treats trailing text as pattern content.

# Python
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.codex-venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Django runtime data
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
private_media/
logs/

# Local environment files and secrets
.env
.env.*
!.env.example
!.env.production
*.pem
*.key
*.crt
*.p12
*.pfx

# Editors and operating systems
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Tests and coverage
.coverage
.coverage.*
.pytest_cache/
htmlcov/

# Database backups
*.bak
*.backup
/db_backups/*.sql
/db_backups/*.dump

# Node.js and frontend builds
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/dist/
frontend/.vite/
frontend/.env.local

# Runtime and temporary files
*.pid
*.seed
*.pid.lock
*.tmp
*.temp
